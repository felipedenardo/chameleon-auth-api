        {
          "name": "Register User (POST /register)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test.user@chameleon.com\",\n    \"password\": \"Senha@123\",\n    \"confirm_password\": \"Senha@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login User (POST /login) & Get Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 200 && jsonData.data) {",
                  "  if (jsonData.data.token) {",
                  "    pm.environment.set(\"auth_token\", jsonData.data.token);",
                  "  }",
                  "  if (jsonData.data.refresh_token) {",
                  "    pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test.user@chameleon.com\",\n    \"password\": \"Senha@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Tokens (POST /refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 200 && jsonData.data) {",
                  "  if (jsonData.data.token) {",
                  "    pm.environment.set(\"auth_token\", jsonData.data.token);",
                  "  }",
                  "  if (jsonData.data.refresh_token) {",
                  "    pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}"
